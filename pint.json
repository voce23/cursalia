{
    "preset": "laravel",
    "rules": {
        "concat_space": {
            "spacing": "none"
        },
        "phpdoc_align": {
            "align": "left"
        },
        "single_trait_insert_per_statement": true,
        "binary_operator_spaces": {
            "default": "single_space"
        },
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        }
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "node_modules",
        "vendor",
        "public/build"
    ]
}
